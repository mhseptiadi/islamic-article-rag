# Copy to .env and adjust values. Precedence: .env > OS environment > defaults.
# Use # for comments (; is also supported at line start).

# --- HTTP API ---
HTTP_PORT=8080

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_HOST=localhost
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=indonesian_articles
QDRANT_ARTICLE_COLLECTION=indonesian_articles_full

# --- LLM (provider: ollama | google | groq) ---
LLM_PROVIDER=ollama
LLM_API_KEY=
# Ollama defaults (when LLM_PROVIDER=ollama):
LLM_API_URL=http://localhost:11434/api/generate
LLM_MODEL=qwen2.5:7b
# Google defaults (when LLM_PROVIDER=google):
# LLM_API_URL=https://generativelanguage.googleapis.com/v1beta
# LLM_MODEL=gemini-2.0-flash
# Groq defaults (when LLM_PROVIDER=groq):
# LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
# LLM_MODEL=openai/gpt-oss-120b

# --- Embeddings ---
EMBEDDING_API_KEY=
OLLAMA_EMBEDDING_URL=http://localhost:11434/api/embeddings
OLLAMA_EMBEDDING_MODEL=bge-m3

# --- Ingestion ---
RAW_ARTICLES_DIR=data/raw_articles
CHUNK_WINDOW_SIZE=3
CHUNK_STEP_SIZE=2
MAX_CHUNK_CHARS=6000

# --- Retrieval ---
MIN_SIMILARITY_SCORE=0.40
